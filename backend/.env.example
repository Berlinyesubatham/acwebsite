# Database Configuration
DATABASE_URL=your_database_url_here

# Email Configuration (Gmail SMTP) - For sending to ADMIN
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Admin Contact Information (Who receives notifications)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_WHATSAPP_NUMBER=+919876543210

# Optional: Twilio WhatsApp API (If you want automated WhatsApp to admin)
# Without this, admin only gets email notifications
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=+1234567890
